---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Declarative Document Format">
  <Nav />
  <main>
    <section class="hero">
      <h1>Documents as code.</h1>
      <p class="tagline">Programmatic document creation is a verbose nightmare — for developers and LLMs alike.<br/>DDF is a concise YAML spec that compiles to .pptx, .docx, and .pdf.</p>
      <div class="install">
        <code>pip install declarativedocs</code>
      </div>
      <div class="hero-links">
        <a href="/docs/getting-started/" class="btn btn-primary">Get Started</a>
        <a href="https://github.com/declarativedocs/compiler-py" class="btn btn-outline">GitHub</a>
      </div>
    </section>

    <section class="example">
      <h2>Write YAML. Get styled documents.</h2>
      <p class="example-note">An entire themed presentation — charts, tables, reusable masters — in a format any LLM can produce:</p>
      <pre><code class="language-yaml">presentation:
  layout: "16x9"
  title: "Acme Corp — Q3 2025 Review"

  theme:
    fonts:
      heading: Georgia
      body: Calibri
    colors:
      primary: "1E2761"
      accent: "F96167"

  masters:
    title_slide:
      background: $primary
      elements:
        - type: text
          text: "&#123;&#123;title&#125;&#125;"
          font: $heading
          size: 44
          color: $white

  slides:
    - master: title_slide
      data:
        title: "Q3 2025 Performance Review"

    - master: content_slide
      data:
        title: "Key Metrics"
      elements:
        - type: group
          layout: row
          items:
            - runs:
                - &#123;text: "$4.2M", size: 40, bold: true&#125;
                - &#123;text: "Revenue", size: 13&#125;

        - type: chart
          chart: bar
          series:
            - name: "Recurring"
              labels: ["Q1", "Q2", "Q3"]
              values: [2800, 3200, 3700]</code></pre>
    </section>

    <section class="features">
      <h2>Why DDF?</h2>
      <div class="feature-grid">
        <div class="feature-card">
          <h3>Built for LLMs</h3>
          <p>A structured, concise format that AI models produce reliably — no more 500-line python-pptx scripts.</p>
        </div>
        <div class="feature-card">
          <h3>Version-controlled documents</h3>
          <p>YAML diffs cleanly. Review deck changes in PRs. Generate reports in CI.</p>
        </div>
        <div class="feature-card">
          <h3>Themed & consistent</h3>
          <p>Define colors and fonts once with <code>$variables</code>. Every slide stays on-brand.</p>
        </div>
        <div class="feature-card">
          <h3>Rich output</h3>
          <p>Charts, tables, groups, shapes, masters — production-ready .pptx from a few lines of YAML.</p>
        </div>
        <div class="feature-card">
          <h3>Simple integration</h3>
          <p><code>ddf report.yaml</code> from the CLI, or <code>compile()</code> from Python. One dependency, no config.</p>
        </div>
        <div class="feature-card">
          <h3>Multi-format</h3>
          <p>One spec for .pptx, .docx, and .pdf. Same YAML concepts, different output targets.</p>
        </div>
      </div>
    </section>

    <footer>
      <p>Created by Kjeld Oostra. Apache-2.0 licensed.</p>
    </footer>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    text-align: center;
    padding: 5rem 0 3rem;
  }
  .hero h1 {
    font-size: 3.5rem;
    color: var(--primary);
  }
  .tagline {
    font-size: 1.2rem;
    color: var(--muted);
    margin-top: 1rem;
    line-height: 1.7;
  }
  .install {
    margin-top: 2rem;
  }
  .install code {
    font-size: 1.1rem;
    padding: 0.6rem 1.2rem;
    background: var(--code-bg);
    color: #e2e8f0;
    border-radius: 6px;
  }
  .hero-links {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.95rem;
  }
  .btn:hover {
    text-decoration: none;
  }
  .btn-primary {
    background: var(--primary);
    color: white;
  }
  .btn-primary:hover {
    background: #151d4a;
  }
  .btn-outline {
    border: 1.5px solid var(--primary);
    color: var(--primary);
  }
  .btn-outline:hover {
    background: var(--primary);
    color: white;
  }

  .example {
    padding: 3rem 0;
  }
  .example h2 {
    text-align: center;
  }
  .example-note {
    text-align: center;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .features {
    padding: 3rem 0;
  }
  .features h2 {
    text-align: center;
    margin-bottom: 2rem;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .feature-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .feature-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }
  .feature-card p {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  footer {
    text-align: center;
    padding: 3rem 0;
    color: var(--muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
  }
</style>
